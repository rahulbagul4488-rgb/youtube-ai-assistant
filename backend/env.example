# ─────────────────────────────────────────────────────────────────────────────
# YouTube AI Assistant — Environment Variables
# Copy this file to ".env" and fill in your values.
# NEVER commit the real .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── REQUIRED ──────────────────────────────────────────────────────────────────
# Get your free token from: https://huggingface.co/settings/tokens
# Create a token with READ permission (free account is enough).
HUGGINGFACEHUB_API_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── OPTIONAL — override defaults ─────────────────────────────────────────────
# CHROMA_PERSIST_DIR=./chroma_db
# EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
# LLM_REPO_ID=meta-llama/Llama-3.1-8B-Instruct
# CHUNK_SIZE=1000
# CHUNK_OVERLAP=200
# TOP_K=4
# MAX_NEW_TOKENS=512
